{
  "name": "cnet",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@cnet/web",
    "dev:api": "turbo dev --filter=@cnet/api",
    "dev:workers": "turbo dev --filter=@cnet/workers",
    "build": "turbo build",
    "lint": "biome check . && bun scripts/sonar-scan-if-configured.ts",
    "lint:check": "biome check .",
    "format": "biome check --write .",
    "db:start": "bun scripts/db.ts start",
    "db:stop": "bun scripts/db.ts stop",
    "db:reset": "bun scripts/db.ts reset",
    "db:generate": "turbo db:generate --filter=@cnet/db",
    "db:migrate": "turbo db:migrate --filter=@cnet/db",
    "db:studio": "turbo db:studio --filter=@cnet/db",
    "tank:clear": "bun scripts/tank.ts clear",
    "cnet-bayd": "bun run apps/bayd/src/index.ts",
    "bridge": "cd apps/neural-bridge && .venv/bin/python -m neural_bridge run"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "sonarqube-scanner": "4.3.6",
    "turbo": "2.9.18",
    "typescript": "5.9.3"
  },
  "overrides": {
    "@vitest/browser": "4.1.10",
    "handlebars": "4.7.9",
    "shell-quote": "1.9.0",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=20.9.0",
    "bun": ">=1.3.4"
  }
}
