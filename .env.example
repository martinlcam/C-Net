# C-Net environment — copy to .env at the repo root and fill in.
# Only the vault-related vars are documented here; see the deploy docs for the rest.

# --- Core (existing) ---
# DATABASE_URL=postgresql://user:pass@localhost:5432/cnet
# REDIS_URL=redis://localhost:6379
# AUTH_SECRET=               # openssl rand -base64 32
# GOOGLE_ID=
# GOOGLE_SECRET=
# NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Vault: multi-user allowlist ---
# JSON array. role is "super" (full dashboard + admin over all vaults) or
# "storage" (Vault only). quota is a binary size ("1T", "500G", "250M") or
# omitted for unlimited. Editing this list adds/removes users; no redeploy of
# the DB is needed (roles/quota resolve live by email).
# VAULT_ALLOWLIST=[{"email":"you@example.com","role":"super"},{"email":"alice@example.com","role":"storage","quota":"1T"}]

# --- Vault: storage backend ---
# Filesystem root for vault bytes. Relative paths resolve from the repo root.
# Local dev default — production uses the bind-mounted tank (see HANDOVER doc).
TANK_MOUNT_PATH=.data/tank

# --- Vault: signing + lifecycle ---
# Secret used to sign short-lived download URLs. Falls back to AUTH_SECRET if unset.
# VAULT_SIGNING_SECRET=
# Hours before an abandoned upload session + its .part file are reaped (Plan 2 worker).
# VAULT_UPLOAD_TTL_HOURS=24
# Days a soft-deleted file stays in trash before purge (Plan 2 worker).
# VAULT_TRASH_TTL_DAYS=30
