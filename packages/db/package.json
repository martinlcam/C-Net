{
  "name": "@cnet/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "dev": "drizzle-kit studio --config=drizzle.config.cjs",
    "db:generate": "drizzle-kit generate --config=drizzle.config.cjs",
    "db:migrate": "bun src/migrate.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.cjs"
  },
  "dependencies": {
    "drizzle-orm": "0.44.7",
    "pg": "8.17.1"
  },
  "devDependencies": {
    "@types/pg": "8.16.0",
    "dotenv": "16.6.1",
    "drizzle-kit": "0.30.6",
    "typescript": "5.9.3"
  }
}
