# Copy to .env (in this folder OR the repo root) and edit. python-dotenv
# loads ./env first, then walks up to the repo root, so either works.

# Bluetooth MAC of your Muse 2 (from `python -m neural_bridge scan`).
# Leave blank to pick the first Muse-* device that scans nearby.
MUSE_ADDRESS=

# Same Redis the rest of C-Net uses (port 6380 in dev, 6379 in prod-ish).
REDIS_URL=redis://localhost:6380

# Channel names — must match apps/realtime + apps/web. Defaults below.
BD_REDIS_CHANNEL_SAMPLES=bd:samples
BD_REDIS_CHANNEL_STATUS=bd:status

# Muse preset. "21" is the standard 4-EEG-channel preset for Muse 2 and is
# what muse-lsl ships as default. Don't change unless you know why.
MUSE_PRESET=21
